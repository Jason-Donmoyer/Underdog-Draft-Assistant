{
    "manifest_version": 3,
    "name": "Draft Assistant",
    "version": "1.0.0",
    "description": "Underdog Battle Royale live draft assistant",
    "icons": {
        "16": "icons/icon16.png",
        "32": "icons/icon32.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "permissions": [
        "storage",
        "scripting",
        "activeTab",
        "sidePanel"
    ],
    "host_permissions": [
        "https://*.underdogsports.com/*",
        "https://*.underdogfantasy.com/*",
        "https://api.fantasypros.com/*",
        "https://api.rotowire.com/*"
    ],
    "background": {
        "service_worker": "src/background/service-worker.js"
    },
    "content_scripts": [
        {
            "matches": ["https://*.underdogsports.com/*", "https://*.underdogfantasy.com/*"],
            "js": ["src/content/content-script.js"],
            "run_at": "document_idle"
        }
        
    ],
    "action": {
        "default_title": "Draft Assistant",
        "default_icon": {
            "16": "icons/icon16.png",
            "32": "icons/icon32.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "side_panel": {
        "default_path": "src/sidebar/sidebar.html"
    }
}